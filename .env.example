# Qrius SaaS Environment Variables
# Copy this file to .env.local and fill in your values
#
# For production deployment on Vercel:
# 1. Go to Project Settings → Environment Variables
# 2. Add each variable for the appropriate environment (Production/Preview/Development)
# 3. Variables prefixed with VITE_ are exposed to the browser
# 4. Other variables are server-side only (keep secrets here!)

# ============================================
# APP CONFIGURATION
# ============================================
# App URL (used for generating tracking URLs and redirects)
# Development: http://localhost:5173
# Production: https://qriuscodes.com
APP_URL=http://localhost:5173

# Base domain for subdomain split (e.g., qriuscodes.com)
# When set, public pages serve on qriuscodes.com and the authenticated app on app.qriuscodes.com.
# Auth sessions are shared via parent-domain cookies.
# Leave empty for local dev (everything runs on a single origin).
VITE_BASE_DOMAIN=

# Short URL domain for QR code tracking redirects
# Production: qrslnk.com
# If not set, uses APP_URL/r/[shortCode]
SHORT_URL_DOMAIN=

# ============================================
# VERCEL API (for custom domain management)
# ============================================
# Required for white-label custom domains feature (Business plan)
# Get from: https://vercel.com/account/tokens
VERCEL_API_TOKEN=
# Get from: Vercel dashboard → Project → Settings → General → Project ID
VERCEL_PROJECT_ID=

# ============================================
# SUPABASE CONFIGURATION
# ============================================
# Get these from: https://supabase.com/dashboard/project/_/settings/api

# Supabase project URL
VITE_SUPABASE_URL=https://your-project.supabase.co

# Supabase anonymous (public) key - safe for browser
VITE_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key - NEVER expose in browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================
# STRIPE CONFIGURATION
# ============================================
# Get these from: https://dashboard.stripe.com/apikeys

# Stripe publishable key - safe for browser
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Stripe secret key - server-side only
STRIPE_SECRET_KEY=sk_test_xxx

# Stripe webhook secret - from webhook endpoint settings
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Stripe Price IDs for subscription plans (monthly)
VITE_STRIPE_PRICE_STARTER=price_xxx
VITE_STRIPE_PRICE_PRO=price_xxx
VITE_STRIPE_PRICE_BUSINESS=price_xxx

# Stripe Price IDs for subscription plans (annual — 22% savings)
VITE_STRIPE_PRICE_STARTER_ANNUAL=price_xxx
VITE_STRIPE_PRICE_PRO_ANNUAL=price_xxx
VITE_STRIPE_PRICE_BUSINESS_ANNUAL=price_xxx

# ============================================
# DATABASE CONFIGURATION
# ============================================
# Neon Postgres Database (if not using Supabase DB)
# Get this from: https://console.neon.tech or Vercel Storage dashboard
POSTGRES_URL=postgres://user:password@host/database?sslmode=require

# ============================================
# CACHING (UPSTASH REDIS)
# ============================================
# Get this from: https://console.upstash.com or Vercel Storage dashboard
KV_REST_API_URL=https://xxx.upstash.io
KV_REST_API_TOKEN=xxx

# ============================================
# SECURITY
# ============================================
# IP Hashing Salt (for privacy-preserving scan logging)
# Generate a random string, e.g.: openssl rand -hex 32
IP_SALT=your-random-salt-string-here

# API Key encryption secret
API_KEY_SECRET=your-api-key-encryption-secret

# ============================================
# OPTIONAL: EMAIL SERVICE
# ============================================
# For sending transactional emails (payment failures, team invites)
# Recommended: Resend (https://resend.com)
# Domain: qriuscodes.com — configure SPF, DKIM, DMARC in Resend dashboard
RESEND_API_KEY=re_xxx

# Cron job authentication secret
# Generate: openssl rand -hex 32
# Required for scan milestones, usage warnings, weekly/monthly digests
CRON_SECRET=your-cron-secret-here

# ============================================
# OPTIONAL: ERROR MONITORING
# ============================================
# Sentry DSN for error tracking
# Get from: https://sentry.io
VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# ============================================
# OPTIONAL: ANALYTICS
# ============================================
# PostHog or other analytics
VITE_POSTHOG_KEY=phc_xxx
VITE_POSTHOG_HOST=https://app.posthog.com

# ============================================
# PRODUCTION CHECKLIST
# ============================================
# Before going live, ensure you have:
#
# Required:
# [ ] VITE_SUPABASE_URL - Production Supabase project URL
# [ ] VITE_SUPABASE_ANON_KEY - Production anon key
# [ ] SUPABASE_SERVICE_ROLE_KEY - Production service role key
# [ ] APP_URL - Your production domain
#
# For payments:
# [ ] VITE_STRIPE_PUBLISHABLE_KEY - Live Stripe key (pk_live_xxx)
# [ ] STRIPE_SECRET_KEY - Live Stripe secret (sk_live_xxx)
# [ ] STRIPE_WEBHOOK_SECRET - Production webhook secret
# [ ] VITE_STRIPE_PRICE_STARTER - Live price ID for Starter plan
# [ ] VITE_STRIPE_PRICE_PRO - Live price ID for Pro plan
# [ ] VITE_STRIPE_PRICE_BUSINESS - Live price ID for Business plan
#
# For caching (recommended):
# [ ] KV_REST_API_URL - Upstash Redis URL
# [ ] KV_REST_API_TOKEN - Upstash Redis token
#
# For security:
# [ ] IP_SALT - Random 64-char hex string
# [ ] API_KEY_SECRET - Random 64-char hex string
